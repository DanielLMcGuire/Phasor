            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "ASSEMBLY": "OFF",
                "CMAKE_APPLE_SILICON_PROCESSOR": "arm64"
            }
        },
