#include <array>
#include <cstddef>
#include <meta> // C++26 Static reflection
#include <ranges>
#include <stdexcept>

/**
 * @brief Enumerated array
 * @tparam Enum Enumerated type
 * @tparam T Array element type
 */
template<typename Enum, typename T>
struct enum_array : std::array<T, std::meta::enumerators_of(^^Enum).size()> {
    static constexpr auto _info = std::meta::enumerators_of(^^Enum);
    static constexpr std::size_t N = _info.size();

    using Base = std::array<T, N>;

    constexpr const T& operator[](Enum e) const {
        return Base::operator[](to_index(e));
    }

    constexpr T& operator[](Enum e) {
        return Base::operator[](to_index(e));
    }

private:
    static constexpr std::size_t to_index(Enum e) {
        constexpr bool is_contiguous = [] {
            auto vals = _info | std::views::transform([](auto e) {
                return static_cast<std::ptrdiff_t>(std::meta::extract<Enum>(e));
            });
            std::ptrdiff_t expected = static_cast<std::ptrdiff_t>(std::meta::extract<Enum>(_info[0]));
            for (auto v : vals) {
                if (v != expected++) return false;
            }
            return true;
        }();

        if constexpr (is_contiguous) {
            return static_cast<std::size_t>(e);
        } else {
            template for (constexpr auto i : std::views::iota(std::size_t{0}, N)) {
                if (e == std::meta::extract<Enum>(_info[i])) {
                    return i;
                }
            }
            throw std::out_of_range("enum_array: invalid enum value");
        }
    }
};