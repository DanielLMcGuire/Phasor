{
  "name": "Phasor IR",
  "scopeName": "source.phasor-ir",
  "fileTypes": ["phir"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#opcodes"
    },
    {
      "include": "#registers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.phasor-ir",
          "match": ";.*$"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "keyword.control.section.phasor-ir",
          "match": "^\\.(PHIR|CONSTANTS|VARIABLES|FUNCTIONS|STRUCTS|INSTRUCTIONS)\\b"
        }
      ]
    },
    "opcodes": {
      "patterns": [
        {
          "name": "keyword.operator.opcode.phasor-ir",
          "match": "\\b(PUSH_CONST|POP|IADD|ISUBTRACT|IMULTIPLY|IDIVIDE|IMODULO|FLADD|FLSUBTRACT|FLMULTIPLY|FLDIVIDE|FLMODULO|SQRT|POW|LOG|EXP|SIN|COS|TAN|NEGATE|NOT|IAND|IOR|IEQUAL|INOT_EQUAL|ILESS_THAN|IGREATER_THAN|ILESS_EQUAL|IGREATER_EQUAL|FLAND|FLOR|FLEQUAL|FLNOT_EQUAL|FLLESS_THAN|FLGREATER_THAN|FLLESS_EQUAL|FLGREATER_EQUAL|JUMP|JUMP_IF_FALSE|JUMP_IF_TRUE|JUMP_BACK|STORE_VAR|LOAD_VAR|PRINT|PRINTERROR|READLINE|IMPORT|HALT|CALL_NATIVE|CALL|SYSTEM|SYSTEM_OUT|SYSTEM_ERR|RETURN|TRUE|FALSE|NULL_VAL|LEN|CHAR_AT|SUBSTR|MOV|LOAD_CONST_R|LOAD_VAR_R|STORE_VAR_R|IADD_R|ISUB_R|IMUL_R|IDIV_R|IMOD_R|FLADD_R|FLSUB_R|FLMUL_R|FLDIV_R|FLMOD_R|SQRT_R|POW_R|LOG_R|EXP_R|SIN_R|COS_R|TAN_R|IAND_R|IOR_R|IEQ_R|INE_R|ILT_R|IGT_R|ILE_R|IGE_R|FLAND_R|FLOR_R|FLEQ_R|FLNE_R|FLLT_R|FLGT_R|FLLE_R|FLGE_R|PUSH_R|PUSH2_R|POP_R|POP2_R|NEG_R|NOT_R|PRINT_R|PRINTERROR_R|READLINE_R|SYSTEM_R|SYSTEM_OUT_R|SYSTEM_ERR_R|EXIT_SCOPE)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.parameter.register.phasor-ir",
          "match": "\\br\\d+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "storage.type.constant.phasor-ir",
          "match": "\\b(NULL|BOOL|INT|FLOAT|STRING)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.phasor-ir",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.phasor-ir",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.phasor-ir",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}