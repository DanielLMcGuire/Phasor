include "./phasor_help.phs";
include "std/main.phs";

fn main(args: string[]) -> int {
    if (args.len() == 3) {
        return ManPage{name: args[1].to_string(), section: args[2].to_int()}.getDocCmd().sys_shell();
    } else if (args.len() == 2) {
        return ManPage{name: args[1], section: 1}.getDocCmd().sys_shell();
    } else {
        showHelp(args[0].fstem(), args.len() > 1);
        return 1;
    }
}