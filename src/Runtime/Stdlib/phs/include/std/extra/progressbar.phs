include "./conemu.phs";

// Hide progress indicator
fn progressBarDone() {
    conemu_progress_reset();
}

// Show progress bar, with conemu GUI support
// percentage: 0-100
// borderLeft: Example: "["
// borderRight: Example: "]"
// fill: Example: "="
// size: Positive integer, size in CLI chars
fn progressBarPercentage(percentage: int, borderLeft: string, borderRight: string, fill: string, size: int);

// Show progress bar, with conemu GUI support from arbitrary units with custom style
// done: how many things (e.g. files) have been processed? (positive)
// total: how many things (e.g. files) are there in total? (positive, greater than `done`)
// borderLeft: Example: "["
// borderRight: Example: "]"
// fill: Example: "="
// size: Positive integer, size in CLI chars
// returns: percentage
fn progressBarUnits(done: int, total: int, borderLeft: string, borderRight: string, fill: string, size: int);

// Show progress bar, with conemu GUI support from arbitrary units
// done: how many things (e.g. files) have been processed? (positive)
// total: how many things (e.g. files) are there in total? (positive, greater than `done`)
// returns: True on 100%
fn progressBarSimple(done: int, total: int) -> bool;

// ----
include "../../../src/std/extra/progressbar.phs";