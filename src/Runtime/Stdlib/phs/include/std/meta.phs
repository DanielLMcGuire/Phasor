using("stdmeta");
include "./types/meta.phs";

fn get_self() -> Bytecode;

fn get_self_instructions() -> InstructionData[];

fn get_self_constants() -> ConstantData[];

fn get_self_variables() -> VariableData[];

fn get_self_functions() -> FunctionData[];

fn get_self_structs() -> StructData[];

fn get_self_global_scopes() -> ScopeData[];

fn run_program(program: Bytecode) -> i64;

fn run_program_function(
    program: Bytecode, 
    functionName: string, 
    func_arguments: any[], 
    cli_arguments: string[]) -> any;

fn get_alloc_info() -> alloc_info;

