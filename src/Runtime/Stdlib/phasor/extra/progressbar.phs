include "extra/conemu.phs";

// Hide progress indicator
fn progressBarDone() {
    conemu_progress_reset();
}

// Show progress bar, with conemu GUI support
// percentage: 0-100
// borderLeft: Example: "["
// borderRight: Example: "]"
// fill: Example: "="
// size: Positive integer, size in CLI chars
fn progressBarPercentage(percentage: int, borderLeft: string, borderRight: string, fill: string, size: int) {
    assert(percentage >= 0 && percentage <= 100);
    conemu_progress(1, percentage);
    var lineEnding: string = "\r";
    
    if (percentage >= 100) {
        lineEnding = "\n";
    }
    
    var fillLength: int = size * percentage / 100;
    
    phs__std_noimport("printf", "%s%.*s%s %d%%%s", borderLeft, fillLength, fill, borderRight, percentage, lineEnding);
    
    if (percentage >= 100) {
        progressBarDone();
    }
}

// Show progress bar, with conemu GUI support from arbitrary units with custom style
// done: how many things (e.g. files) have been processed? (positive)
// total: how many things (e.g. files) are there in total? (positive, greater than `done`)
// borderLeft: Example: "["
// borderRight: Example: "]"
// fill: Example: "="
// size: Positive integer, size in CLI chars
// returns: percentage
fn progressBarUnits(done: int, total: int, borderLeft: string, borderRight: string, fill: string, size: int) -> int {
    assert(done >= 0 && total >= 0 && done <= total);
    var percentage: int = (done * 100) / total;

    progressBarPercentage(percentage, borderLeft, borderRight, fill, size);
    return percentage;
}

// Show progress bar, with conemu GUI support from arbitrary units
// done: how many things (e.g. files) have been processed? (positive)
// total: how many things (e.g. files) are there in total? (positive, greater than `done`)
// returns: True on 100%
fn progressBarSimple(done: int, total: int) -> bool {
    return progressBarUnits(done, total, "[", "]", "=", 15) == 100;
}