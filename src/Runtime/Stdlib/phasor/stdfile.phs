using("stdfile");
include "extra/progressbar.phs";

fn fcp_progress(files: string[], dest: string) -> bool {
    for (var i: int = 0; i < files.length; i++) {
        
        if (!fcp(files[i], fjoin(dest, fname(files[i])))) {
            return false;
        }
        progressBarSimple(i + 1, files.length);
    }
    return true;
}