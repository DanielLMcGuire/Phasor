// libloaderapi.phs -- Win32 | libloaderapi
// https://learn.microsoft.com/en-us/windows/win32/api/libloaderapi/
include "./wintypes.phs";

fn GetModuleHandle(ModuleName: any) -> HANDLE {
    if (ModuleName == null) return HANDLE{ data: win32_GetModuleHandleA(null) };
    else return HANDLE{ data: win32_GetModuleHandleA(phs__noimport("to_string", ModuleName)) };
}

fn LoadLibrary(LibFileName: string) -> HINSTANCE {
    return HANDLE{ data: LoadLibraryA(LibFileName) };
}