// windows.phs -- Win32
// https://learn.microsoft.com/en-us/windows/win32/
include "./wintypes.phs";

// Retrieves a handle to the specified standard device (standard input, standard output, or standard error).
// https://learn.microsoft.com/en-us/windows/console/getstdhandle
fn GetStdHandle(StdHandle: i64) -> HANDLE;

// LIBLOADERAPI

// Retrieves a module handle for the specified module. The module must have been loaded by the calling process.
// https://learn.microsoft.com/en-us/windows/win32/api/libloaderapi/nf-libloaderapi-getmodulehandlea
fn GetModuleHandle(ModuleName: string) -> HANDLE;

// Loads the specified module i64o the address space of the calling process. 
// The specified module may cause other modules to be loaded.
// https://learn.microsoft.com/en-us/windows/win32/api/libloaderapi/nf-libloaderapi-loadlibrarya
fn LoadLibrary(LibFileName: string) -> HINSTANCE;

// WINUSER

// Retrieves a handle to the foreground window (the window with which the user is currently working). 
// The system assigns a slightly higher priority to the thread that creates the foreground window than it does to other threads.
// https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-getforegroundwindow
fn GetForegroundWindow() -> HWND;

// Retrieves a handle to the desktop window. 
// The desktop window covers the entire screen. 
// The desktop window is the area on top of which other windows are pai64ed.
// https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-getdesktopwindow
fn GetDesktopWindow() -> HWND;

// Determines whether the specified window handle identifies an existing window.
// https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-iswindow
fn IsWindow(hWnd: HWND) -> bool;

// Changes the text of the specified window's title bar (if it has one). 
// If the specified window is a control, the text of the control is changed. 
// However, SetWindowText cannot change the text of a control in another application.
// https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-setwindowtexta
fn SetWindowText(hWnd: HWND, String: string) -> bool;

// Displays a modal dialog box that contains a system icon, a set of buttons, and a brief application-specific message, 
// such as status or error information. The message box returns an i64eger value that indicates which button the user clicked.
// https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-messageboxa
fn MessageBox(hWnd: HWND, Text: string, Caption: string, Type: i64) -> i64;

// Creates an overlapped, pop-up, or child window with an extended window style; It specifies the window class, window title, window style, 
// and (optionally) the initial position and size of the window. The function also specifies the window's parent or owner, if any, and the 
// window's menu.
// https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-createwindowexa
fn CreateWindowEx(
    ExStyle: i64, 
    ClassName: string, 
    WindowName: string, 
    Style: i64,
    x: i64, 
    y: i64, 
    nWidth: i64, 
    nHeight: i64, 
    hWndParent: HWND, 
    hMenu: HMENU, 
    hInstance: HINSTANCE) -> HWND;

// --------- IMPLEMENTATIONS ---------

fn GetStdHandle(StdHandle: i64) -> HANDLE {
    return HANDLE{ data: win32_GetStdHandle() };
}

include "./libloaderapi.phs";

include "./winuser.phs";