#!/usr/bin/env phasor
include "./clocf/types.phs";
include "./clocf/logic.phs";
include "std/io.phs";
include "std/type.phs";
include "std/main.phs";

fn main(args: string[]) -> int {
    if (args.len() > 1 && (args[1] == "--help" || args[1] == "-h")) {
        print_help();
        return 0;
    }

    if (args.len() > 1 && (args[1] == "--from-json")) {
        var state: ClocState = args[2].from_json();
        processResults(state).puts();
        return 0;
    }

    var state: ClocState = createState();
    readInput(state);

    if (state.totalCode == 0) {
        puts_error("Error: No cloc data received via pipe.");
        return 1;
    }

    if (args.len() > 1 && (args[1] == "--json")) {
        if (args.len() == 3)
        state.to_json(args[2].to_int()).puts();
        else state.to_json().puts();
        return 0;
    }

    processResults(state).puts();
    return 0;
}