#!/usr/bin/env phasor
using("stdsys", "stdio", "stdstr", "stdfile", "stdtype", "stdarray", "stdmem");

struct LangEntry {
    name: string,
    code: int
}

struct ClocState {
    entries:    LangEntry[],
    totalCode:  int,
    maxNameLen: int
}

fn print_help() -> void {
    puts("clocf - cloc formatter\n");
    puts("Usage:");
    puts("  cloc [options] <path> | clocf         Process cloc output");
    puts("  clocf --help                          Show this help\n");
    puts("Examples:");
    puts("  cloc . | clocf                        Pipe cloc output");
}

fn createState() -> ClocState {
    return ClocState{
        entries:    [],
        totalCode:  0,
        maxNameLen: 0
    };
}

fn trimRight(s: string) -> string {
    var end: int = len(s) - 1;
    while (end >= 0 && (char_at(s, end) == " " || char_at(s, end) == "\t")) {
        end = end - 1;
    }
    if (end < 0) return "";
    return substr(s, 0, end + 1);
}

fn isDigit(c: string) -> bool {
    return (c == "0" || c == "1" || c == "2" || c == "3" || c == "4" ||
            c == "5" || c == "6" || c == "7" || c == "8" || c == "9");
}

fn parseLine(line: string) -> LangEntry {
    var lineLen: int = len(line);
    var empty: LangEntry = LangEntry{ name: "", code: 0 };

    var nameEnd: int = 0;
    while (nameEnd < lineLen && !isDigit(char_at(line, nameEnd))) {
        nameEnd = nameEnd + 1;
    }

    if (nameEnd == 0 || nameEnd >= lineLen)
        return empty;

    var namePart: string = trimRight(substr(line, 0, nameEnd));
    if (len(namePart) == 0) return empty;

    var pos: int = nameEnd;
    var nums: int[] = [];

    while (pos < lineLen && len(nums) < 4) {
        while (pos < lineLen && char_at(line, pos) == " ")
            pos = pos + 1;

        var numStr: string = "";
        while (pos < lineLen && isDigit(char_at(line, pos))) {
            var tempSb: int = sb_new();
            sb_append(tempSb, numStr);
            sb_append(tempSb, char_at(line, pos));
            numStr = sb_free(tempSb);
            pos = pos + 1;
        }

        if (len(numStr) > 0)
            nums = arr_push(nums, to_int(numStr));
        else
            break;
    }

    if (len(nums) < 4) return empty;

    return LangEntry{
        name: namePart,
        code: nums[3]
    };
}

fn shouldSkipLine(line: string) -> bool {
    return (
        starts_with(line, "github.com/AlDanial/cloc") ||
        starts_with(line, "-") ||
        starts_with(line, "Language") ||
        starts_with(line, "SUM")
    );
}

fn readInput(state: ClocState) -> void {
    while (true) {
        var line: string = gets();
        if (len(line) == 0) break;
        if (shouldSkipLine(line)) continue;

        var entry: LangEntry = parseLine(line);

        if (len(entry.name) > 0 && entry.code > 0) {
            state.entries   = arr_push(state.entries, entry);
            state.totalCode = state.totalCode + entry.code;

            if (len(entry.name) > state.maxNameLen)
                state.maxNameLen = len(entry.name);
        } else {
            free("entry");
        }
    }
}

fn padRight(s: string, width: int) -> string {
    var sb: int = sb_new();
    sb_append(sb, s);
    for (var p: int = 0; p < width - len(s); p++)
        sb_append(sb, " ");
    return sb_free(sb);
}

fn processResults(state: ClocState) -> string {
    putf("Total code lines: %d\n", state.totalCode);
    puts("Language percentages:");

    var ret: string = "";
    for (var k: int = 0; k < len(state.entries); k++) {
        var entry: LangEntry = state.entries[k];
        var percent: float = (entry.code * 100.0) / state.totalCode;
        ret = concat(ret, c_fmt("%s : %6.2f%% (%d lines)\n", padRight(entry.name, state.maxNameLen), percent, entry.code));
        free("entry");
    }
    return ret;
}

fn main(args: string[]) -> int {
    if (len(args) > 1 && (args[1] == "--help" || args[1] == "-h")) {
        print_help();
        return 0;
    }

    var state: ClocState = createState();
    readInput(state);

    if (state.totalCode == 0) {
        puts_error("Error: No cloc data received via pipe.");
        return 1;
    }

    if (len(args) > 1 && (args[1] == "--json")) {
        puts(state);
        return 0;
    }

    puts(processResults(state));
    return 0;
}

shutdown(main(sys_args()));