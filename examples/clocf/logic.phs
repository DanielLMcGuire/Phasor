include "std/io.phs";
include "std/str.phs";
include "std/type.phs";
include "std/mem.phs";
include "std/array.phs";

fn print_help() -> void {
    puts("clocf - cloc formatter\n");
    puts("Usage:");
    puts("  cloc [options] <path> | clocf         Process cloc output");
    puts("  clocf --help                          Show this help\n");
    puts("Examples:");
    puts("  cloc . | clocf                        Pipe cloc output");
}

fn createState() -> ClocState {
    return ClocState{
        entries:    [],
        totalCode:  0,
        maxNameLen: 0
    };
}

fn trimRight(s: string) -> string {
    var end: int = s.len() - 1;
    while (end >= 0 && (s.char_at(end) == " " || s.char_at(end) == "\t")) {
        end--;
    }
    if (end < 0) return "";
    return substr(s, 0, end + 1);
}

fn isDigit(c: string) -> bool {
    return (c == "0" || c == "1" || c == "2" || c == "3" || c == "4" ||
            c == "5" || c == "6" || c == "7" || c == "8" || c == "9");
}

fn parseLine(line: string) -> LangEntry {
    var lineLen: int = line.len();
    var empty: LangEntry = LangEntry{ name: "", code: 0 };

    var nameEnd: int = 0;
    while (nameEnd < lineLen && !isDigit(line.char_at(nameEnd))) {
        nameEnd++;
    }

    if (nameEnd == 0 || nameEnd >= lineLen)
        return empty;

    var namePart: string = trimRight(substr(line, 0, nameEnd));
    if (namePart.len() == 0) return empty;

    var pos: int = nameEnd;
    var nums: int[] = [];

    while (pos < lineLen && nums.len() < 4) {
        while (pos < lineLen && line.char_at(pos) == " ")
            pos = pos + 1;

        var numStr: string = "";
        while (pos < lineLen && isDigit(line.char_at(pos))) {
            numStr = numStr.concat(line.char_at(pos));
            pos = pos + 1;
        }

        if (numStr.len() > 0)
            nums = nums.arr_push(to_int(numStr));
        else
            break;
    }

    if (nums.len() < 4) return empty;

    return LangEntry{
        name: namePart,
        code: nums[3]
    };
}

fn shouldSkipLine(line: string) -> bool {
    return (
        starts_with(line, "github.com/AlDanial/cloc") ||
        starts_with(line, "-") ||
        starts_with(line, "Language") ||
        starts_with(line, "SUM")
    );
}

fn readInput(state: ClocState) -> void {
    while (true) {
        var line: string = gets();
        if (line.len() == 0) break;
        if (shouldSkipLine(line)) continue;

        var entry: LangEntry = parseLine(line);

        if (entry.name.len() > 0 && entry.code > 0) {
            state.entries   = state.entries.arr_push(entry);
            state.totalCode = state.totalCode + entry.code;

            if (entry.name.len() > state.maxNameLen)
                state.maxNameLen = entry.name.len();
        } else {
            free("entry");
        }
    }
}

fn processResults(state: ClocState) -> string {
    putf("Total code lines: %d\n", state.totalCode);
    puts("Language percentages:");
    var ret: string = "";
    
    for (var k: int = 0; k < state.entries.len(); k++) {
        var entry: LangEntry = state.entries[k];
        var percent: float = (entry.code * 100.0) / state.totalCode;
        ret = concat(ret, c_fmt( "%-*s : %6.2f%% (%d lines)\n", state.maxNameLen, entry.name, percent, entry.code));
    }
    return ret;
}