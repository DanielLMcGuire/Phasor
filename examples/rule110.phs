#!/usr/bin/env phasor
include "./rule110/logic.phs";
include "std/type.phs";
include "std/main.phs";

fn main(args: string[]) -> int {
    if (args.len() < 4) {
        printHelp(args[0].fstem()).puts();
        return 1;
    }
    var width: int = args[1].to_int();
    var generations: int = args[2].to_int();
    var stdout: bool = false;
    if (args.len() == 4 && (args[3].to_string() == "true" || args[3].to_string() == "t"))
        stdout = true;
    return rule110(width, generations, stdout);
}