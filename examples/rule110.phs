#!/usr/bin/env phasor
using("stdio", "stdstr", "stdtype", "stdsys", "stdfile", "stdarray");

var logfile = "outfile.txt";

struct ChunkStats {
    chunk_time: float,
    total_time: float,
    eta: float,
    generation_start: int,
    generation_end: int
}

struct Rule110State {
    width: int,
    generations: int,
    stdout: bool,

    board: array,
    next_board: array,

    generation: int,

    start_time: float,
    last_chunk_start: float,

    avg_chunk_time: float,
    avg_chunk_count: float
}

fn secondsToMinutes(seconds: float) -> string {

    if (seconds < 60)
        return c_fmt("%fs", seconds);

    var mins = seconds / 60;
    var secs = seconds % 60;

    if (secs < 10)
        return c_fmt("%d:0%ds", mins, secs);

    return c_fmt("%d:%ds", mins, secs);
}

fn msToSeconds(milli: float) -> float {
    return milli / 1000;
}

fn createBoard(width: int) -> array {

    var board = [];

    for (var i = 0; i < width; i++) {
        board = arr_push(board, false);
    }

    board[width - 1] = true;

    return board;
}

fn boardToString(board: array) -> string {

    var sb = sb_new();

    for (var i = 0; i < len(board); i++) {

        if (board[i]) {
            sb_append(sb, "#");
        } else {
            sb_append(sb, " ");
        }
    }

    var out = sb_to_string(sb);

    sb_free(sb);

    return out;
}

fn createState(
    width: int,
    generations: int,
    stdout: bool
) -> Rule110State {

    return Rule110State{
        width: width,
        generations: generations,
        stdout: stdout,

        board: createBoard(width),
        next_board: createBoard(width),

        generation: 0,

        start_time: time(),
        last_chunk_start: time(),

        avg_chunk_time: 0.0,
        avg_chunk_count: 0.0
    };
}

fn computeNextGeneration(state: Rule110State) {
    for (var k = 0; k < state.width; k++) {

        var l = false;

        if (k > 0)
            l = state.board[k - 1];

        var c = state.board[k];

        var r = false;

        if (k < state.width - 1)
            r = state.board[k + 1];

        var next_val = false;

        if (
            (c && !r) ||
            (!c && r) ||
            (!l && c && r)
        ) {
            next_val = true;
        }

        state.next_board[k] = next_val;
    }

    var tmp = state.board;
    state.board = state.next_board;
    state.next_board = tmp;
}

fn calculateChunkStats(
    state: Rule110State,
    generation: int,
    now: float
) -> ChunkStats {

    var chunk_time =
        msToSeconds(now - state.last_chunk_start);

    state.avg_chunk_time =
        state.avg_chunk_time + chunk_time;

    state.avg_chunk_count =
        state.avg_chunk_count + 1;

    var average =
        state.avg_chunk_time /
        state.avg_chunk_count;

    var chunks_done =
        state.avg_chunk_count;

    var chunks_total =
        state.generations / 500.0;

    var eta =
        (chunks_total - chunks_done) * average;

    return ChunkStats{
        chunk_time: chunk_time,
        total_time: msToSeconds(now - state.start_time),
        eta: eta,
        generation_start: generation - 499,
        generation_end: generation
    };
}

fn printChunkStats(stats: ChunkStats) {

    prints("\r                                                                        ");

    printf(
        "\rGENERATION %d-%d TIME: %s, TOTAL: %s, ETA: %s",
        stats.generation_start,
        stats.generation_end,
        secondsToMinutes(stats.chunk_time),
        secondsToMinutes(stats.total_time),
        secondsToMinutes(stats.eta)
    );
}

fn rule110(
    width: int,
    generations: int,
    stdout: bool
) -> int {

    if (!stdout)
        puts(concat("Output at ", logfile));

    frm(logfile);

    var state =
        createState(width, generations, stdout);

    var file_buffer = sb_new();

    if (!stdout) {

        printf(
            "GENERATION 0 TIME: %s",
            secondsToMinutes(
                msToSeconds(time() - state.start_time)
            )
        );
    }

    for (g = 0; g <= generations; g++) {

        state.generation = g;

        var board_string =
            boardToString(state.board);

        if (stdout)
            puts(board_string);

        sb_append(file_buffer, board_string);
        sb_append(file_buffer, "\n");

        computeNextGeneration(state);

        if (g != 0 && (g % 500 == 0)) {

            var chunk = sb_to_string(file_buffer);
    fappend(logfile, chunk);

            sb_free(file_buffer);
            file_buffer = sb_new();

            if (!stdout) {

                var now = time();

                var stats =
                    calculateChunkStats(
                        state,
                        g,
                        now
                    );

                printChunkStats(stats);

                state.last_chunk_start = now;
            }
        }
    }

    var chunk = sb_to_string(file_buffer);
    fappend(logfile, chunk);

    sb_free(file_buffer);

    putf(
        "\nTOTAL: %s",
        secondsToMinutes(
            msToSeconds(time() - state.start_time)
        )
    );

    return 0;
}

if (sys_argc() < 4)
    shutdown(rule110(2085, 25050, false));

shutdown(
    rule110(
        to_int(sys_argv(1)),
        to_int(sys_argv(2)),
        to_int(sys_argv(3))
    )
);