include "./types.phs";
include "stdfile.phs";
include "stdarray.phs";
include "stdsys.phs";
include "stdio.phs";
include "stdstr.phs";

var logfile: string = "outfile.txt";

fn secondsToMinutes(seconds: float) -> string {

    if (seconds < 60)
        return c_fmt("%fs", seconds);

    var mins: int = seconds / 60;
    var secs: int = seconds % 60;

    if (secs < 10)
        return c_fmt("%d:0%ds", mins, secs);

    return c_fmt("%d:%ds", mins, secs);
}

fn msToSeconds(milli: float) -> float {
    return milli / 1000;
}

fn createBoard(width: int) -> bool[] {
    var board: bool[] = [];

    for (var i: int = 0; i < width; i++) {
        board = board.arr_push(false);
    }

    board[width - 1] = true;
    return board;
}

fn boardToString(board: bool[]) -> string {
    var sb: int = sb_new().sb_prealloc(board.len());

    for (var i: int = 0; i < board.len(); i++) {

        if (board[i]) {
            sb.sb_append("#");
        } else {
            sb.sb_append(" ");
        }
    }

    return sb.sb_free();
}

fn createState(
    width: int,
    generations: int,
    stdout: bool
) -> Rule110State {

    return Rule110State{
        width: width,
        generations: generations,
        stdout: stdout,

        board: createBoard(width),
        next_board: createBoard(width),

        generation: 0,

        start_time: time(),
        last_chunk_start: time(),

        avg_chunk_time: 0.0,
        avg_chunk_count: 0.0
    };
}

fn computeNextGeneration(state: Rule110State) -> void {
    var l: bool = false;
    var c: bool = state.board[0];
    
    for (var k: int = 0; k < state.width; k++) {
        var r: bool = false;
        
        if (k < state.width - 1) {
            r = state.board[k + 1];
        }

        var next_val: bool = false;
        if ((c && !r) || (!c && r) || (!l && c && r)) {
            next_val = true;
        }

        state.next_board[k] = next_val;

        l = c;
        c = r;
    }

    var tmp: bool[] = state.board;
    state.board = state.next_board;
    state.next_board = tmp;
}

fn calculateChunkStats(state: Rule110State, generation: int, now: float) -> ChunkStats {

    var chunk_time: float =
        msToSeconds(now - state.last_chunk_start);

    state.avg_chunk_time =
        state.avg_chunk_time + chunk_time;

    state.avg_chunk_count =
        state.avg_chunk_count + 1;

    var average: float =
        state.avg_chunk_time /
        state.avg_chunk_count;

    var chunks_done: float =
        state.avg_chunk_count;

    var chunks_total: float =
        state.generations / 500.0;

    var eta: float =
        (chunks_total - chunks_done) * average;

    return ChunkStats{
        chunk_time: chunk_time,
        total_time: msToSeconds(now - state.start_time),
        eta: eta,
        generation_start: generation - 499,
        generation_end: generation
    };
}

fn printChunkStats(stats: ChunkStats) -> void {

    prints("\r                                                                        ");

    printf("\rGENERATION %d-%d TIME: %s, TOTAL: %s, ETA: %s",
        stats.generation_start,
        stats.generation_end,
        secondsToMinutes(stats.chunk_time),
        secondsToMinutes(stats.total_time),
        secondsToMinutes(stats.eta)
    );
}

fn rule110(width: int, generations: int, stdout: bool) -> int {

    if (!stdout)
        concat("Output at ", logfile).puts();

    var fd: int = fopen(logfile, "w");

    var state: Rule110State =
        createState(width, generations, stdout);

    var file_buffer: int = sb_new().sb_prealloc(generations * 500);

    if (!stdout) {
        printf("GENERATION 0 TIME: %s", secondsToMinutes(
            msToSeconds(time() - state.start_time)
        ));
    }

    for (var g: int = 0; g <= generations; g++) {
        state.generation = g;

        var board_string: string =
            boardToString(state.board);

        if (stdout)
            board_string.puts();

        file_buffer.sb_append(board_string);
        file_buffer.sb_append("\n");
        computeNextGeneration(state);

        if (g != 0 && (g % 500 == 0)) {
            var chunk: string = file_buffer.sb_to_string();
            file_buffer.sb_clear();
            fwrite(fd, chunk);

            if (!stdout) {
                var now: float = time();
                var stats: ChunkStats =
                    calculateChunkStats(
                        state,
                        g,
                        now
                    );

                printChunkStats(stats);
                state.last_chunk_start = now;
            }
        }
    }

    var chunk: string = file_buffer.sb_free();
    
    fwrite(fd, chunk);
    fclose(fd);

    putf(
        "\nTOTAL: %s",
        secondsToMinutes(
            msToSeconds(time() - state.start_time)
        )
    );

    return 0;
}

fn printHelp(programName: string) -> string {
    return c_fmt(`phasor %s WIDTH GENERATIONS STDOUT
    WIDTH - Width of board
    GENERATIONS - Length of board
    STDOUT - Print out to stdout? (true/false)`, programName);
}