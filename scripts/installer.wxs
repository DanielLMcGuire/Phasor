          Name="Path" Type="string" Value="[INSTALLFOLDER]bin" />
      </Component>

      <Component Id="AppPaths_phasordecomp" Guid="*" Bitness="always64">
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasordecomp.exe"
          Type="string" Value="[INSTALLFOLDER]bin\phasordecomp.exe" KeyPath="yes" />
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasordecomp.exe"
          Name="Path" Type="string" Value="[INSTALLFOLDER]bin" />
      </Component>

      <Component Id="AppPaths_phasorvm" Guid="*" Bitness="always64">
