<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Phasor Programming Language"
           Manufacturer="Phasor"
           Version="3.2.0.0"
           UpgradeCode="21b71c69-201d-480c-9366-b01ea4e16cb9"
           Scope="perMachine">

    <Launch Condition="VersionNT64" Message="This program requires a 64-bit processor." />

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <WixVariable Id="WixUILicenseRtf" Value="..\assets\LICENSE.rtf" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Phasor Programming Language" />
    </StandardDirectory>

    <Icon Id="PhasorIcon" SourceFile="..\assets\phasor.ico" />
    <Property Id="ARPPRODUCTICON" Value="PhasorIcon" />

    <Feature Id="MainFeature" Title="Phasor" Level="1">
      <ComponentGroupRef Id="PhasorFiles" />

      <ComponentRef Id="PhasorIcon_Comp" />

      <ComponentRef Id="PathEnv" />

      <ComponentRef Id="AppPaths_phasor" />
      <ComponentRef Id="AppPaths_phasorasm" />
      <ComponentRef Id="AppPaths_phasorcompiler" />
      <ComponentRef Id="AppPaths_phasordecomp" />
      <ComponentRef Id="AppPaths_phasorvm" />
      <ComponentRef Id="AppPaths_phasor_lsp" />
      <ComponentRef Id="AppPaths_pulsar" />
      <ComponentRef Id="AppPaths_pulsarcompiler" />

      <ComponentRef Id="HKCRApps_phasor" />
      <ComponentRef Id="HKCRApps_phasorasm" />
      <ComponentRef Id="HKCRApps_phasorcompiler" />
      <ComponentRef Id="HKCRApps_phasordecomp" />
      <ComponentRef Id="HKCRApps_phasorvm" />
      <ComponentRef Id="HKCRApps_pulsar" />
      <ComponentRef Id="HKCRApps_pulsarcompiler" />

      <ComponentRef Id="FileAssoc_phsb" />
      <ComponentRef Id="FileAssoc_phs" />
      <ComponentRef Id="FileAssoc_phir" />
      <ComponentRef Id="FileAssoc_pul" />

      <ComponentRef Id="Capabilities_phasor" />
      <ComponentRef Id="Capabilities_phasorasm" />
      <ComponentRef Id="Capabilities_phasorcompiler" />
      <ComponentRef Id="Capabilities_phasordecomp" />
      <ComponentRef Id="Capabilities_phasorvm" />
      <ComponentRef Id="Capabilities_pulsar" />
      <ComponentRef Id="Capabilities_pulsarcompiler" />
    </Feature>

    <DirectoryRef Id="INSTALLFOLDER">

      <Component Id="PhasorIcon_Comp" Guid="*">
        <File Id="phasor.ico" Source="..\assets\phasor.ico" />
      </Component>

      <Component Id="PathEnv" Guid="*">
        <RegistryValue Root="HKLM" Key="Software\Phasor\Install"
                       Name="PathSet" Type="integer" Value="1" KeyPath="yes" />
        <Environment Id="PhasorBinPath" Name="PATH" Value="[INSTALLFOLDER]bin"
                     Permanent="no" Part="last" Action="set" System="yes" />
      </Component>

      <Component Id="AppPaths_phasor" Guid="*" Bitness="always64">
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasor.exe"
          Type="string" Value="[INSTALLFOLDER]bin\phasor.exe" KeyPath="yes" />
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasor.exe"
          Name="Path" Type="string" Value="[INSTALLFOLDER]bin" />
      </Component>

      <Component Id="AppPaths_phasorasm" Guid="*" Bitness="always64">
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasorasm.exe"
          Type="string" Value="[INSTALLFOLDER]bin\phasorasm.exe" KeyPath="yes" />
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasorasm.exe"
          Name="Path" Type="string" Value="[INSTALLFOLDER]bin" />
      </Component>

      <Component Id="AppPaths_phasorcompiler" Guid="*" Bitness="always64">
