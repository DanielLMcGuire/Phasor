        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\phasor-lsp.exe"
          Name="Path" Type="string" Value="[INSTALLFOLDER]bin" />
      </Component>

      <Component Id="AppPaths_pulsar" Guid="*" Bitness="always64">
        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\pulsar.exe"
          Type="string" Value="[INSTALLFOLDER]bin\pulsar.exe" KeyPath="yes" />
        <RegistryValue Root="HKLM"
