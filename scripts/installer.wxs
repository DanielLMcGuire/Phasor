        <RegistryValue Root="HKLM"
          Key="Software\Microsoft\Windows\CurrentVersion\App Paths\pulsarcompiler.exe"
          Name="Path" Type="string" Value="[INSTALLFOLDER]bin" />
      </Component>

      <Component Id="HKCRApps_phasor" Guid="*">
        <RegistryValue Root="HKCR" Key="Applications\phasor.exe"
          Name="FriendlyAppName" Type="string" Value="Phasor" KeyPath="yes" />
        <RegistryValue Root="HKCR" Key="Applications\phasor.exe\DefaultIcon"
          Type="string" Value="[INSTALLFOLDER]bin\phasor.exe" />
        <RegistryValue Root="HKCR" Key="Applications\phasor.exe\SupportedTypes"
          Name=".phsb" Type="string" Value="" />
        <RegistryValue Root="HKCR" Key="Applications\phasor.exe\SupportedTypes"
          Name=".phs" Type="string" Value="" />
        <RegistryValue Root="HKCR" Key="Applications\phasor.exe\shell\open\command"
          Type="string" Value="&quot;[INSTALLFOLDER]bin\phasor.exe&quot; &quot;%1&quot; %*" />
